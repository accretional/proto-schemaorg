(* subClassOf: RadioChannel *)
SchemaAMRadioChannel = 
    id (* text *)
    , { additionalType (* text *) }
    , { alternateName (* text *) }
    , { broadcastChannelId (* text *) }
    , { broadcastFrequency }
    , { broadcastServiceTier (* text *) }
    , { description }
    , { disambiguatingDescription (* text *) }
    , { genre }
    , { identifier }
    , { image }
    , { inBroadcastLineup }
    , { mainEntityOfPage }
    , { name (* text *) }
    , { owner }
    , { potentialAction }
    , { providesBroadcastService }
    , { sameAs (* text *) }
    , { subjectOf }
    , { url (* text *) } ;

