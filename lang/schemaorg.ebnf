(* subClassOf: RadioChannel *)
SchemaAMRadioChannel = 
    <id>
    , { <additionalType> }
    , { <alternateName> }
    , { <broadcastChannelId> }
    , { broadcastFrequency }
    , { <broadcastServiceTier> }
    , { description }
    , { <disambiguatingDescription> }
    , { genre }
    , { identifier }
    , { image }
    , { inBroadcastLineup }
    , { mainEntityOfPage }
    , { <name> }
    , { owner }
    , { potentialAction }
    , { providesBroadcastService }
    , { <sameAs> }
    , { subjectOf }
    , { <url> } ;

